---
import "@/styles/global.css";
import { book } from "@data/book";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, "https://systemology.com").toString();
const fullTitle = title === book.title ? `${title} — Read free online` : `${title} | SYSTEMology`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- CC BY 4.0 license declaration #1: HTTP Link header equivalent in meta -->
    <link rel="license" href={book.license} />
    <meta name="DC.rights" content={book.licenseShort} />

    <!-- Open Graph -->
    <meta property="og:type" content="book" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SYSTEMology" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="book:author" content="David Jenyns" />
    <meta property="book:isbn" content={book.isbn13} />
    <meta property="book:release_date" content={book.datePublished} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Citation metadata (Highwire) -->
    <meta name="citation_title" content={book.title} />
    <meta name="citation_author" content="David Jenyns" />
    <meta name="citation_publication_date" content={book.datePublished} />
    <meta name="citation_isbn" content={book.isbn13} />
    <meta name="citation_publisher" content={book.publisher.name} />

    <!-- Preconnect to Wistia -->
    <link rel="preconnect" href="https://fast.wistia.net" />
    <link rel="dns-prefetch" href="https://fast.wistia.com" />

    <!-- Slot for per-page schema -->
    <slot name="schema" />
  </head>
  <body>
    <header class="border-b border-stone-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-3 flex items-center justify-between">
        <a href="/pdf/" class="text-lg font-semibold text-brand-navy no-underline">
          SYSTEMology
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/pdf/" class="hover:text-orange-600">Read</a>
          <a href="https://systemology.com/book/" class="hover:text-orange-600">Buy</a>
          <a href="https://systemology.com/resources/" class="hover:text-orange-600">Resources</a>
          <a href="https://systemhub.com/" class="hover:text-orange-600">systemHUB</a>
        </nav>
      </div>
    </header>

    <main class="min-h-screen">
      <slot />
    </main>

    <footer class="mt-20 border-t border-stone-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-stone-600">
        <div class="flex flex-wrap items-start justify-between gap-6">
          <div>
            <p class="font-semibold text-brand-navy">SYSTEMology</p>
            <p>by David Jenyns · Rethink Press, 2020 · ISBN {book.isbn13}</p>
          </div>
          <div class="text-sm" itemscope itemtype="http://creativecommons.org/ns#License">
            <p>
              Released free under <a
                href={book.license}
                rel="license"
                class="underline">CC BY 4.0</a>
            </p>
            <p>You are free to read, share, quote, and translate with attribution.</p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
