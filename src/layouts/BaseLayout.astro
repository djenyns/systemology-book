---
import "@/styles/global.css";
import { book, SAMPLE_MODE } from "@data/book";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  bodyClass?: string;
}

const { title, description, canonical, ogImage, bodyClass = "" } = Astro.props;
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, "https://www.systemology.com").toString();
const fullTitle =
  title === book.title ? `${title} — Read free online` : `${title} — SYSTEMology`;
const resolvedOgImage = ogImage ?? "https://www.systemology.com/pdf/brand/og-image.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#081d3d" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Favicon — sourced from systemology.com */}
    <link rel="icon" type="image/png" sizes="60x60" href="/pdf/brand/favicon-60.png" />
    <link rel="icon" type="image/png" sizes="133x133" href="/pdf/brand/favicon.png" />
    <link rel="apple-touch-icon" href="/pdf/brand/favicon.png" />

    {/* Open Sans (UI/headings) + Source Serif 4 (reading body) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600&display=swap"
      rel="stylesheet"
    />

    {/* CC BY-NC-ND 4.0 license — full free web edition only, not sample mode */}
    {!SAMPLE_MODE && <link rel="license" href={book.license} />}
    {!SAMPLE_MODE && <meta name="DC.rights" content={book.licenseShort} />}

    {/* Open Graph */}
    <meta property="og:type" content="book" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SYSTEMology" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="book:author" content="David Jenyns" />
    <meta property="book:isbn" content={book.isbn13} />
    <meta property="book:release_date" content={book.datePublished} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    {/* Citation metadata (Highwire) */}
    <meta name="citation_title" content={book.title} />
    <meta name="citation_author" content="David Jenyns" />
    <meta name="citation_publication_date" content={book.datePublished} />
    <meta name="citation_isbn" content={book.isbn13} />
    <meta name="citation_publisher" content={book.publisher.name} />

    <link rel="preconnect" href="https://fast.wistia.net" />
    <link rel="dns-prefetch" href="https://fast.wistia.com" />

    {/* Google Analytics 4 — same property as the rest of systemology.com */}
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-SP44Y9LJ21"></script>
    <script is:inline define:vars={{ id: "G-SP44Y9LJ21" }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", id);
    </script>

    {/* HubSpot — tracking + live-chat widget (single script handles both) */}
    <script
      is:inline
      type="text/javascript"
      id="hs-script-loader"
      async
      defer
      src="//js.hs-scripts.com/45129160.js"
    ></script>

    <slot name="schema" />
  </head>
  <body class={bodyClass}>
    <div class="warning">
      Heads up: this site uses CSS Grid. Your browser is older than that — content may look unstyled but everything still reads.
    </div>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="https://www.systemology.com/" class="site-header__brand" aria-label="SYSTEMology home">
          <img
            src="/pdf/brand/systemology-logo-white.png"
            alt="SYSTEMology"
            class="site-header__logo"
            width="250"
            height="38"
          />
        </a>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="/pdf/">Table of Contents</a>
          <a href={book.amazonUrl} class="site-header__cta">Buy the book</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__brand">SYSTEMology</p>
        <p>
          by David Jenyns · Rethink Press, 2020 · ISBN {book.isbn13}
        </p>
        {!SAMPLE_MODE && (
          <p>
            Published online free under <a
              href={book.license}
              rel="license">{book.licenseShort}</a>. You are free to read and share it, in
            full and unchanged, for non-commercial use, with attribution.
          </p>
        )}
        <p style="margin-top: 1.5em;">
          Prefer print? <a href={book.amazonUrl}>Get the paperback or Kindle</a> ·
          <a href={book.audibleUrl}> Listen on Audible</a>
        </p>
        <p style="margin-top: 1.5em; font-size: 0.85em; opacity: 0.7;">
          © {new Date().getFullYear()} David Jenyns / SYSTEMology. Some rights reserved.
        </p>
      </div>
    </footer>

    {/* CTA click tracking → GA4 `cta_click` event. Instruments EXISTING CTAs only;
        adds no CTAs and changes no content. Delegated capture-phase listener. */}
    <script is:inline>
      document.addEventListener(
        "click",
        function (e) {
          var a = e.target && e.target.closest ? e.target.closest("a[href]") : null;
          if (!a) return;
          var href = a.getAttribute("href") || "";
          var label = null;
          if (/amazon\./i.test(href)) label = "amazon";
          else if (/audible\./i.test(href)) label = "audible";
          else if (/systemhub\.com/i.test(href)) label = "systemhub";
          else if (/\/getcertified/i.test(href)) label = "get_certified";
          else if (/book-raves/i.test(href)) label = "book_raves";
          else if (/^\/pdf\/[^/]+\/$/.test(href) && a.classList.contains("btn-cta"))
            label = "start_reading";
          if (!label) return;
          var path = window.location.pathname.replace(/\/$/, "");
          var loc = path === "/pdf" || path === "" ? "hub" : path.split("/").pop();
          if (typeof gtag === "function") {
            gtag("event", "cta_click", {
              cta_label: label,
              cta_location: loc,
              link_url: href,
            });
          }
        },
        true
      );
    </script>
  </body>
</html>
