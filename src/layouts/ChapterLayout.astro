---
import BaseLayout from "./BaseLayout.astro";
import BookSchema from "@components/BookSchema.astro";
import CitationBlock from "@components/CitationBlock.astro";
import AudioPlayer from "@components/AudioPlayer.astro";
import { chaptersBySlug, chapters, type Chapter } from "@data/book";

interface Props {
  slug: string;
  description: string;
}

const { slug, description } = Astro.props;
const chapter: Chapter = chaptersBySlug[slug];

if (!chapter) {
  throw new Error(`Unknown chapter slug: ${slug}`);
}

// Find prev/next in reading order
const stageOrder = chapters.map((c) => c.slug);
const idx = stageOrder.indexOf(slug);
const prev = idx > 0 ? chapters[idx - 1] : null;
const next = idx < chapters.length - 1 ? chapters[idx + 1] : null;
---

<BaseLayout title={chapter.title} description={description}>
  <BookSchema slot="schema" chapter={chapter} description={description} />

  <article class="mx-auto max-w-2xl px-4 py-12">
    <header class="mb-10 not-prose">
      {chapter.number !== null && (
        <p class="text-sm font-semibold uppercase tracking-wide text-orange-600">
          Stage {chapter.number} of 7
        </p>
      )}
      <h1 class="mt-2 text-4xl md:text-5xl font-bold text-brand-navy">
        {chapter.title}
      </h1>
      <p class="mt-3 text-xl text-stone-600 italic">
        {chapter.subtitle}
      </p>
      <div class="mt-4 flex items-center gap-4 text-sm text-stone-500">
        <span>📖 {chapter.estReadMinutes} min read</span>
        {chapter.estAudioMinutes > 0 && <span>🎧 {chapter.estAudioMinutes} min audio</span>}
      </div>

      {chapter.audioFile && (
        <AudioPlayer
          audioFile={chapter.audioFile}
          durationMinutes={chapter.estAudioMinutes}
        />
      )}

      {chapter.myth && (
        <aside class="mt-8 rounded-lg border-l-4 border-orange-500 bg-orange-50 p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-orange-700">
            Myth busted
          </p>
          <p class="mt-1 text-base text-brand-navy">{chapter.myth}</p>
        </aside>
      )}
    </header>

    <div class="prose prose-lg prose-stone max-w-none prose-headings:font-display prose-headings:text-brand-navy prose-a:text-orange-600">
      <slot />
    </div>

    <CitationBlock chapter={chapter} />

    <nav class="mt-12 flex items-center justify-between border-t border-stone-200 pt-6 not-prose">
      {prev ? (
        <a href={`/pdf/${prev.slug}/`} class="group">
          <p class="text-xs uppercase tracking-wide text-stone-500">← Previous</p>
          <p class="text-base font-semibold text-brand-navy group-hover:text-orange-600">
            {prev.title}
          </p>
        </a>
      ) : <span />}

      <a href="/pdf/" class="text-sm text-stone-500 hover:text-orange-600">
        ↑ Table of Contents
      </a>

      {next ? (
        <a href={`/pdf/${next.slug}/`} class="text-right group">
          <p class="text-xs uppercase tracking-wide text-stone-500">Next →</p>
          <p class="text-base font-semibold text-brand-navy group-hover:text-orange-600">
            {next.title}
          </p>
        </a>
      ) : <span />}
    </nav>
  </article>
</BaseLayout>
