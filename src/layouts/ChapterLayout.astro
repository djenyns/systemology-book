---
import BaseLayout from "./BaseLayout.astro";
import BookSchema from "@components/BookSchema.astro";
import AudioPlayer from "@components/AudioPlayer.astro";
import WistiaVideo from "@components/WistiaVideo.astro";
import { chaptersBySlug, chapters, isLive, BOOK_URL, type Chapter } from "@data/book";

interface Props {
  slug: string;
  description: string;
  /** Optional list of {id, label} for the in-chapter mini-TOC sidebar.
   * Manually curated from the chapter's H2s — keeps anchor IDs stable. */
  sections?: Array<{ id: string; label: string }>;
}

const { slug, description, sections = [] } = Astro.props;
const chapter: Chapter = chaptersBySlug[slug];

if (!chapter) {
  throw new Error(`Unknown chapter slug: ${slug}`);
}

const stageOrder = chapters.map((c) => c.slug);
const idx = stageOrder.indexOf(slug);
const next = idx < chapters.length - 1 ? chapters[idx + 1] : null;
const prev = idx > 0 ? chapters[idx - 1] : null;

// Sample mode: neighbours that aren't published online link to the book sales page.
const chapterHref = (c: Chapter) => (isLive(c) ? `/pdf/${c.slug}/` : BOOK_URL);

const masthead = chapter.number !== null
  ? `Stage ${chapter.number} of 7`
  : chapter.slug === "introduction"
    ? "Begin here"
    : chapter.slug === "foreword"
      ? "Foreword"
      : chapter.slug === "now-is-the-time"
        ? "The closer"
        : chapter.slug === "epilogue"
          ? "Epilogue"
          : chapter.slug === "glossary"
            ? "Reference"
            : chapter.slug === "about"
              ? "Author"
              : "";
---

<BaseLayout title={chapter.title} description={description}>
  <BookSchema slot="schema" chapter={chapter} description={description} />

  <div class="wb">
    {/* Sticky in-chapter sidebar — Shape Up's killer pattern */}
    <aside class="wb__sidebar">
      <div class="intro__content--sticky">
        {masthead && <p class="intro__masthead">{masthead}</p>}
        <h2 class="intro__title">{chapter.title}</h2>

        {sections.length > 0 && (
          <ul class="intro__sections" id="chapter-toc">
            {sections.map((s) => (
              <li>
                <a href={`#${s.id}`} data-anchor={s.id}>{s.label}</a>
              </li>
            ))}
          </ul>
        )}

        {chapter.cogImage && (
          <div class="intro__cog">
            <img src={chapter.cogImage} alt={`Stage ${chapter.number} cog`} loading="lazy" />
          </div>
        )}

        {next && (
          <div class="intro__next">
            <span class="intro__next-label">Next</span>
            <a href={chapterHref(next)}>{next.title} →</a>
          </div>
        )}

        <div class="intro__nav">
          {prev && (
            <p>
              <a href={chapterHref(prev)}>← Back to {prev.title}</a>
            </p>
          )}
          <p>
            <a href="/pdf/">↑ Table of Contents</a>
          </p>
        </div>

        {!chapter.cogImage && (
          <a
            href="https://www.amazon.com/dp/B08CDY993G"
            class="intro__ad"
            target="_blank"
            rel="noopener"
            aria-label="Get SYSTEMology on Amazon"
          >
            <img
              src="/pdf/brand/amazon-book-ad.jpg"
              alt="Get SYSTEMology on Amazon"
              loading="lazy"
            />
            <p class="intro__ad-caption">Get the paperback on Amazon →</p>
          </a>
        )}
      </div>
    </aside>

    {/* Main content */}
    <article class="wb__content">
      <header class="chapter__header">
        {masthead && <p class="chapter__masthead">{masthead}</p>}
        <h1 class="chapter__title">{chapter.title}</h1>

        {chapter.myth && (
          <p class="chapter__abstract section-rule">
            <em>Myth busted:</em> {chapter.myth}
          </p>
        )}

        {chapter.videoWistiaId && (
          <WistiaVideo
            wistiaId={chapter.videoWistiaId}
            label={chapter.videoLabel}
          />
        )}

        {chapter.audioFile && (
          <AudioPlayer
            audioFile={chapter.audioFile}
            durationMinutes={chapter.estAudioMinutes}
            wistiaId={chapter.audioWistiaId}
            narrator={chapter.audioNarrator}
          />
        )}
      </header>

      <div class="chapter__body">
        <slot />
      </div>

      <nav class="chapter__footer-nav">
        {prev ? (
          <a href={chapterHref(prev)} class="chapter__footer-link chapter__footer-link--prev">
            <span class="chapter__footer-label">← Previous</span>
            <span class="chapter__footer-title">{prev.title}</span>
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a href={chapterHref(next)} class="chapter__footer-link chapter__footer-link--next">
            <span class="chapter__footer-label">{isLive(next) ? "Next →" : "Continue in the book →"}</span>
            <span class="chapter__footer-title">{next.title}</span>
          </a>
        ) : (
          <span />
        )}
      </nav>
    </article>
  </div>

  {/* Mini-TOC active-section highlighter — IntersectionObserver, no deps */}
  {sections.length > 0 && (
    <script is:inline>
      (() => {
        const links = document.querySelectorAll("#chapter-toc a[data-anchor]");
        const map = new Map();
        links.forEach((a) => {
          const id = a.dataset.anchor;
          const target = document.getElementById(id);
          if (target) map.set(target, a);
        });

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const a = map.get(entry.target);
            if (!a) return;
            if (entry.isIntersecting) {
              links.forEach((l) => l.classList.remove("is-active"));
              a.classList.add("is-active");
            }
          });
        }, { rootMargin: "-30% 0px -60% 0px" });

        map.forEach((_, target) => observer.observe(target));
      })();
    </script>
  )}
</BaseLayout>
