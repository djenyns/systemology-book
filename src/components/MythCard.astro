---
interface Props {
  number: number;
  myth: string;
  chapterSlug: string;
  chapterTitle: string;
  printPage: number;
}

const { number, myth, chapterSlug, chapterTitle, printPage } = Astro.props;
---

<article class="myth-card not-prose">
  <div class="myth-card__num">#{number}</div>
  <div class="myth-card__body">
    <p class="myth-card__myth">{myth}</p>
    <a class="myth-card__bust" href={`/pdf/${chapterSlug}/`}>
      Busted in <strong>{chapterTitle}</strong>
      <span class="myth-card__page">print page {printPage}</span>
      <span class="myth-card__arrow" aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style is:global>
  .myth-grid {
    display: grid;
    gap: 1.2em;
    margin: 2.5em 0;
  }

  .myth-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4em;
    align-items: stretch;
    padding: 1.4em 1.6em;
    background: #fff;
    border: 1px solid rgb(var(--color-border));
    border-left: 6px solid rgb(var(--color-gold));
    border-radius: 6px;
    box-shadow: 0 1px 3px rgba(8, 29, 61, 0.06);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .myth-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(8, 29, 61, 0.10);
  }

  .myth-card__num {
    font-family: "Open Sans", sans-serif;
    font-size: 2.1rem;
    font-weight: 700;
    color: rgb(var(--color-cyan));
    line-height: 1;
    align-self: center;
    min-width: 3ch;
  }

  .myth-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.55em;
  }

  .myth-card__myth {
    margin: 0;
    font-family: "Source Serif 4", serif;
    font-size: 1.08rem;
    font-weight: 700;
    line-height: 1.45;
    color: rgb(var(--color-navy));
  }

  .myth-card__bust {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5em;
    font-family: "Open Sans", sans-serif;
    font-size: 0.9rem;
    color: rgb(var(--color-navy));
    text-decoration: none;
    border-bottom: none;
  }

  .myth-card__bust strong {
    color: rgb(var(--color-cyan));
    font-weight: 700;
  }

  .myth-card__page {
    color: rgb(var(--color-text-muted));
    font-size: 0.85rem;
  }

  .myth-card__arrow {
    color: rgb(var(--color-gold));
    font-weight: 700;
    transition: transform 0.18s ease;
  }

  .myth-card__bust:hover {
    text-decoration: none;
  }

  .myth-card__bust:hover .myth-card__arrow {
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .myth-card {
      grid-template-columns: 1fr;
      gap: 0.4em;
      padding: 1.2em 1.3em;
    }
    .myth-card__num {
      font-size: 1.6rem;
    }
  }
</style>
