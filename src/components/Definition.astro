---
/**
 * Inline definition — DefinedTerm schema, stable anchor, glossary cross-link.
 *
 * Use inline in chapter prose: <Definition term="Critical Client Flow" slug="critical-client-flow">
 *   the 10-15 systems that move a customer from lead to repeat buyer
 * </Definition>
 */
interface Props {
  term: string;
  slug: string;
}

const { term, slug } = Astro.props;
const glossaryUrl = `/pdf/glossary/${slug}/`;
---

<span
  class="inline-block"
  itemscope
  itemtype="https://schema.org/DefinedTerm"
  id={`def-${slug}`}
>
  <dfn itemprop="name" title={`Defined term — see glossary`}>
    <a href={glossaryUrl} class="no-underline hover:underline">{term}</a>
  </dfn>
  <span itemprop="description" class="hidden">
    <slot />
  </span>
</span>
