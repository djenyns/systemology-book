---
/**
 * Inline definition — DefinedTerm schema, glossary cross-link.
 *
 * Renders a <dfn> with dotted underline. Hover = "see glossary" cursor.
 * Click = navigate to the glossary entry.
 */
interface Props {
  term: string;
  slug: string;
}

const { term, slug } = Astro.props;
const glossaryUrl = `/pdf/glossary/${slug}/`;
---

<span
  itemscope
  itemtype="https://schema.org/DefinedTerm"
  id={`def-${slug}`}
>
  <dfn itemprop="name" title="See glossary">
    <a href={glossaryUrl}>{term}</a>
  </dfn>
  <meta itemprop="description" content={undefined} />
  <span itemprop="description" hidden>
    <slot />
  </span>
</span>
