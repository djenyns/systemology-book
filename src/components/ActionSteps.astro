---
/**
 * Action Steps block — appears at the end of stage chapters.
 * "What to do tomorrow morning" — dark navy callout per Dave's preference.
 * Marked up with HowTo schema.
 */
---

<aside class="action-steps not-prose" itemscope itemtype="https://schema.org/HowTo">
  <p class="action-steps__masthead">What to do next</p>
  <div class="action-steps__body" itemprop="step">
    <slot />
  </div>
</aside>

<style is:global>
  .action-steps {
    margin: 3em 0 2em 0;
    padding: 2em 2em;
    background: rgb(var(--color-navy));
    color: rgba(255, 255, 255, 0.92);
    border-radius: 6px;
    border-left: 6px solid rgb(var(--color-gold));
    font-family: "Source Serif 4", serif;
  }
  .action-steps__masthead {
    font-size: 0.75em;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgb(var(--color-gold));
    font-family: "Open Sans", sans-serif;
    font-weight: 700;
    margin: 0 0 1.2em 0;
  }
  .action-steps__body p {
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 1em 0;
    line-height: 1.6;
  }
  .action-steps__body p:last-child {
    margin-bottom: 0;
  }
  .action-steps__body strong {
    color: rgb(var(--color-gold));
    font-weight: 700;
  }
  .action-steps__body ol,
  .action-steps__body ul {
    margin: 0;
    padding-left: 1.6em;
  }
  .action-steps__body li {
    margin: 0.6em 0;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.5;
  }
  .action-steps__body ol li::marker,
  .action-steps__body ul li::marker {
    color: rgb(var(--color-cyan));
    font-weight: 700;
  }
  .action-steps__body a {
    color: rgb(var(--color-cyan));
    text-decoration: underline;
    text-decoration-color: rgba(97, 198, 234, 0.5);
  }
  .action-steps__body a:hover {
    color: rgb(var(--color-gold));
  }
</style>
