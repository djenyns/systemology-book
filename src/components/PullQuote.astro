---
/**
 * Pull-quote block — citation-friendly markup that AI engines can deep-link.
 *
 * Wraps in <blockquote cite="..."> with stable anchor ID per quote.
 * The text stays inline-quotable for LLMs that prefer text fragments.
 */
interface Props {
  id: string; // stable anchor — used in #:~:text= deep-links
  attribution?: string; // default: David Jenyns, SYSTEMology
}

const { id, attribution = "David Jenyns, SYSTEMology" } = Astro.props;
---

<figure class="pull-quote my-10 not-prose" id={id}>
  <blockquote
    cite={`https://systemology.com/pdf/`}
    class="border-l-4 border-orange-500 pl-6 py-2 italic text-2xl leading-snug text-brand-navy font-serif"
    itemscope
    itemtype="https://schema.org/Quotation"
  >
    <span itemprop="text">
      <slot />
    </span>
  </blockquote>
  <figcaption class="mt-2 text-sm text-stone-500 pl-6">
    — <span itemprop="author">{attribution}</span>
  </figcaption>
</figure>
