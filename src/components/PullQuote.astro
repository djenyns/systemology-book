---
/**
 * Pull-quote — classic left-rule italic per Shape Up convention.
 * Uses native <blockquote> + Quotation schema for AI citation.
 *
 * Use sparingly. Most emphasis should be **bold** + *italic* inline.
 */
interface Props {
  id: string; // stable anchor for #:~:text= deep-links
  cite?: string; // who said it, default Jenyns
}

const { id, cite } = Astro.props;
---

<blockquote
  id={id}
  cite="https://www.systemology.com/pdf/"
  itemscope
  itemtype="https://schema.org/Quotation"
>
  <p itemprop="text"><slot /></p>
  {cite && (
    <cite itemprop="author">— {cite}</cite>
  )}
</blockquote>
