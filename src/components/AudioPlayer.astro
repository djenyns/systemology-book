---
/**
 * Audio chapter player.
 * - Wistia: uses Wistia's audio-mode inline embed (fixed-height bar, no video container)
 * - Local fallback: native <audio> element for dev
 */
interface Props {
  audioFile: string;
  durationMinutes: number;
  wistiaId?: string;
  narrator?: string;
}

const { audioFile, durationMinutes, wistiaId, narrator = "David Jenyns" } = Astro.props;
const localSrc = audioFile ? `/audio/${encodeURIComponent(audioFile)}` : null;
---

{wistiaId ? (
  <div class="audio-player audio-player--wistia">
    <p class="audio-player__label">
      <span aria-hidden="true">🎧</span>
      <strong>Listen to this chapter</strong> — {durationMinutes} min, narrated by {narrator}
    </p>
    <div
      class={`wistia_embed wistia_async_${wistiaId} seo=true`}
      style="height:90px; width:100%;"
    >&nbsp;</div>
    <script src="https://fast.wistia.com/assets/external/E-v1.js" async is:inline></script>
  </div>
) : localSrc ? (
  <div class="audio-player audio-player--native">
    <p class="audio-player__label">
      <span aria-hidden="true">🎧</span>
      <strong>Listen to this chapter</strong> — {durationMinutes} min, narrated by {narrator}
    </p>
    <audio controls preload="none" style="width:100%;">
      <source src={localSrc} type="audio/mpeg" />
    </audio>
  </div>
) : null}

<style>
  .audio-player__label {
    margin: 0 0 0.6em 0;
    font-size: 0.9em;
    font-family: "Open Sans", sans-serif;
    color: rgb(var(--color-charcoal));
    display: flex;
    align-items: center;
    gap: 0.5em;
  }
  .audio-player__label strong {
    color: rgb(var(--color-navy));
  }
</style>
