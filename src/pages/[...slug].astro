---
import { getCollection, render } from "astro:content";
import ChapterLayout from "@layouts/ChapterLayout.astro";
import { chaptersBySlug, isLive } from "@data/book";

export async function getStaticPaths() {
  const entries = await getCollection("chapters");
  // Sample mode: locked chapters keep their MDX source but aren't built.
  return entries
    .filter((entry) => {
      const chapter = chaptersBySlug[entry.data.slug];
      return chapter && isLive(chapter);
    })
    .map((entry) => ({
      params: { slug: entry.data.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

/**
 * Sidebar mini-TOC sections per chapter — manually curated for stable anchors.
 * Each chapter's MDX must use the same H2 IDs that appear here.
 */
const sectionsBySlug: Record<string, Array<{ id: string; label: string }>> = {};

const sections = sectionsBySlug[entry.data.slug] ?? [];
---

<ChapterLayout
  slug={entry.data.slug}
  description={entry.data.description}
  sections={sections}
>
  <Content />
</ChapterLayout>
