---
import BaseLayout from "@layouts/BaseLayout.astro";
import BookSchema from "@components/BookSchema.astro";
import CitationBlock from "@components/CitationBlock.astro";
import { book, chapters, stageChapters } from "@data/book";

const description =
  "Read the full SYSTEMology book free online. The seven-step framework for systemising your business — Define, Assign, Extract, Organise, Integrate, Scale, Optimise. By David Jenyns. Free under CC BY 4.0.";
---

<BaseLayout title={book.title} description={description}>
  <BookSchema slot="schema" description={description} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    <header class="text-center mb-12">
      <p class="text-sm font-semibold uppercase tracking-wide text-orange-600">
        The complete book — free online
      </p>
      <h1 class="mt-3 text-5xl md:text-6xl font-bold text-brand-navy">
        {book.title}
      </h1>
      <p class="mt-4 text-xl text-stone-700 max-w-2xl mx-auto">
        {book.subtitle}
      </p>
      <p class="mt-3 text-stone-500">
        by <a href={book.author.url} class="underline">{book.author.name}</a>
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm">
        <a
          href={book.amazonUrl}
          class="rounded-md border border-stone-300 bg-white px-4 py-2 hover:border-orange-500 hover:text-orange-600"
        >Get on Kindle / Paperback</a>
        <a
          href={book.audibleUrl}
          class="rounded-md border border-stone-300 bg-white px-4 py-2 hover:border-orange-500 hover:text-orange-600"
        >Listen on Audible</a>
      </div>
    </header>

    <section class="mb-12 rounded-lg bg-white p-6 border border-stone-200">
      <p class="text-stone-700 leading-relaxed">
        SYSTEMology is the step-by-step framework for taking yourself out of the
        daily grind of your business. Across seven stages — Define, Assign, Extract,
        Organise, Integrate, Scale, Optimise — you'll move from owner-dependent
        chaos to a business that runs without you.
      </p>
      <p class="mt-3 text-stone-700 leading-relaxed">
        The full book is published here, free, under <a
          href={book.license}
          rel="license"
          class="underline">{book.licenseShort}</a>. Read it. Quote it. Share it.
        Translate it. The only ask is attribution.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Read the book</h2>
      <ol class="space-y-3">
        {chapters.map((c, i) => (
          <li class="border border-stone-200 rounded-lg p-4 bg-white hover:border-orange-500 transition-colors">
            <a href={`/pdf/${c.slug}/`} class="flex items-baseline justify-between gap-4 no-underline">
              <div>
                <p class="text-xs uppercase tracking-wide text-stone-500">
                  {c.number !== null ? `Stage ${c.number}` : i === 0 ? "Begin here" : ""}
                </p>
                <p class="text-lg font-semibold text-brand-navy">{c.title}</p>
                <p class="text-sm text-stone-600 mt-1">{c.subtitle}</p>
              </div>
              <p class="text-xs text-stone-400 whitespace-nowrap">
                {c.estReadMinutes} min
              </p>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <CitationBlock />
  </article>
</BaseLayout>
