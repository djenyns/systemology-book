<style>
/* ========================================
   SYSTEMology 404 — scoped to .syso-404
   ======================================== */
.syso-404 {
  --navy: #081d3d;
  --navy-deep: #04112a;
  --navy-mid: #0c2a52;
  --navy-light: #133766;
  --cyan: #61c6ea;
  --cyan-bright: #00b8d4;
  --cyan-soft: #8ed6ef;
  --gold: #ffc400;
  --white: #ffffff;
  --text-light: rgba(255,255,255,0.7);
  --text-light-strong: rgba(255,255,255,0.92);
  --font-stack: 'Myriad Pro', 'Open Sans', Arial, Helvetica, sans-serif;
  font-family: var(--font-stack);
  background: var(--navy-deep);
  color: var(--text-light-strong);
  margin: 0 calc(50% - 50vw);
  width: 100vw;
  min-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100px 24px;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}
.syso-404 *, .syso-404 *::before, .syso-404 *::after { box-sizing: border-box; }

/* grain overlay */
.syso-404::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1;
}

.syso-404 .syso-content {
  position: relative;
  z-index: 2;
  max-width: 960px;
  text-align: center;
  width: 100%;
}

/* Section label */
.syso-404 .syso-label {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-bottom: 28px;
}
.syso-404 .syso-label::before,
.syso-404 .syso-label::after {
  content: '';
  width: 32px;
  height: 2px;
  background: var(--cyan);
  flex-shrink: 0;
}
.syso-404 .syso-label span {
  font-weight: 700;
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--cyan);
}

/* Big 404 number */
.syso-404 .syso-big {
  font-family: var(--font-stack);
  font-weight: 800;
  font-size: clamp(100px, 18vw, 200px);
  line-height: 1;
  margin-bottom: 8px;
  user-select: none;
  letter-spacing: -0.02em;
}
.syso-404 .syso-big .digit {
  display: inline-block;
  position: relative;
  color: transparent;
  -webkit-text-stroke: 2px rgba(97, 198, 234, 0.28);
  transition: transform 0.4s ease, filter 0.4s ease;
  cursor: default;
}
.syso-404 .syso-big .digit::after {
  content: attr(data-digit);
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  overflow: hidden;
  color: var(--cyan);
  -webkit-text-stroke: 0;
  clip-path: inset(100% 0 0 0);
  transition: clip-path 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.syso-404 .syso-big .digit:hover::after { clip-path: inset(0 0 0 0); }
.syso-404 .syso-big .digit:hover {
  transform: translateY(-4px);
  filter: drop-shadow(0 8px 24px rgba(97, 198, 234, 0.35));
}

/* Headline */
.syso-404 .syso-headline,
.syso-404 h1.syso-headline {
  font-family: var(--font-stack) !important;
  font-weight: 700 !important;
  font-size: clamp(1.6rem, 3.2vw, 2.4rem) !important;
  line-height: 1.2 !important;
  color: var(--white) !important;
  margin: 0 0 20px !important;
  background: transparent !important;
  -webkit-text-fill-color: var(--white) !important;
  white-space: nowrap !important;
}
@media (max-width: 720px) {
  .syso-404 .syso-headline,
  .syso-404 h1.syso-headline {
    white-space: normal !important;
  }
}
.syso-404 .syso-headline em {
  font-style: italic;
  color: var(--white) !important;
  -webkit-text-fill-color: var(--white) !important;
  font-weight: 700;
}
.syso-404 .syso-body {
  color: var(--text-light) !important;
  -webkit-text-fill-color: rgba(255,255,255,0.7) !important;
}

/* Body text */
.syso-404 .syso-body {
  font-size: 1.1rem;
  line-height: 1.7;
  color: var(--text-light);
  margin: 0 auto 40px;
  max-width: 540px;
}

/* Flowchart */
.syso-404 .syso-flow {
  margin: 0 auto 48px;
  max-width: 400px;
}
.syso-404 .syso-step {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 20px;
  border: 1px solid rgba(97, 198, 234, 0.2);
  background: rgba(8, 29, 61, 0.6);
  cursor: pointer;
  transition: all 0.35s ease;
  position: relative;
  opacity: 0;
  transform: translateY(12px);
  border-radius: 4px;
}
.syso-404 .syso-step.visible { opacity: 1; transform: translateY(0); }
.syso-404 .syso-step:hover {
  border-color: var(--cyan);
  background: rgba(19, 55, 102, 0.5);
  transform: translateX(4px);
}
.syso-404 .syso-step.active {
  border-color: var(--cyan);
  background: rgba(97, 198, 234, 0.1);
  box-shadow: 0 0 0 1px rgba(97, 198, 234, 0.15);
}
.syso-404 .syso-step.completed {
  border-color: rgba(97, 198, 234, 0.4);
  opacity: 0.55;
}
.syso-404 .syso-step.completed .syso-step-icon {
  background: var(--cyan);
  color: var(--navy-deep);
  border-color: var(--cyan);
}
.syso-404 .syso-step-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1.5px solid var(--cyan);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.8rem;
  color: var(--cyan);
  flex-shrink: 0;
  transition: all 0.3s ease;
}
.syso-404 .syso-step-text {
  font-weight: 500;
  font-size: 0.95rem;
  color: var(--text-light-strong);
  text-align: left;
}
.syso-404 .syso-connector {
  width: 1px;
  height: 20px;
  background: rgba(97, 198, 234, 0.25);
  margin: 0 auto;
  position: relative;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.syso-404 .syso-connector.visible { opacity: 1; }
.syso-404 .syso-connector::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 50%;
  transform: translateX(-50%);
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 5px solid rgba(97, 198, 234, 0.4);
}
.syso-404 .syso-step.final {
  border-color: var(--cyan);
  background: rgba(97, 198, 234, 0.1);
  cursor: default;
  justify-content: center;
}
.syso-404 .syso-step.final .syso-step-text {
  color: var(--cyan);
  font-weight: 600;
  text-align: center;
}

/* Buttons */
.syso-404 .syso-btn-row {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 8px;
}
.syso-404 .syso-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-stack);
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 15px 32px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  text-decoration: none !important;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.syso-404 .syso-btn--cyan {
  background: var(--cyan-bright);
  color: var(--white) !important;
}
.syso-404 .syso-btn--cyan:hover {
  background: var(--cyan);
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(97, 198, 234, 0.35);
  color: var(--white) !important;
}
.syso-404 .syso-btn--outline {
  background: transparent;
  color: var(--text-light-strong) !important;
  border: 1.5px solid rgba(255,255,255,0.3);
}
.syso-404 .syso-btn--outline:hover {
  border-color: var(--cyan);
  color: var(--cyan) !important;
  transform: translateY(-2px);
}
.syso-404 .syso-btn .arrow { transition: transform 0.3s ease; }
.syso-404 .syso-btn:hover .arrow { transform: translateX(4px); }

/* Fade-in */
@keyframes sysoFadeIn {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
.syso-404 .syso-fade {
  animation: sysoFadeIn 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  opacity: 0;
}
.syso-404 .syso-d1 { animation-delay: 0.1s; }
.syso-404 .syso-d2 { animation-delay: 0.2s; }
.syso-404 .syso-d3 { animation-delay: 0.35s; }
.syso-404 .syso-d4 { animation-delay: 0.5s; }
.syso-404 .syso-d5 { animation-delay: 0.65s; }
.syso-404 .syso-d6 { animation-delay: 0.8s; }

/* Mobile */
@media (max-width: 768px) {
  .syso-404 { padding: 80px 20px; }
  .syso-404 .syso-btn-row { flex-direction: column; align-items: center; }
  .syso-404 .syso-btn { width: 100%; max-width: 300px; justify-content: center; }
}
</style>

<section class="syso-404">
  <div class="syso-content">

    <div class="syso-label syso-fade syso-d1">
      <span>Error 404</span>
    </div>

    <div class="syso-big syso-fade syso-d2">
      <span class="digit" data-digit="4">4</span><span class="digit" data-digit="0">0</span><span class="digit" data-digit="4">4</span>
    </div>

    <h1 class="syso-headline syso-fade syso-d3">
      This page hasn&#8217;t been <em>systemised</em> yet.
    </h1>

    <p class="syso-body syso-fade syso-d4">
      Looks like this process is missing from the manual. Don&#8217;t worry — even the best businesses have a few undocumented pages lying around. Let&#8217;s get you back on track.
    </p>

    <!-- Interactive diagnose-the-problem flowchart -->
    <div class="syso-flow syso-fade syso-d5" id="sysoFlow">
      <div class="syso-step" data-step="1" id="sysoStep1">
        <div class="syso-step-icon">1</div>
        <div class="syso-step-text">Identify the broken process</div>
      </div>
      <div class="syso-connector" id="sysoConn1"></div>

      <div class="syso-step" data-step="2" id="sysoStep2">
        <div class="syso-step-icon">2</div>
        <div class="syso-step-text">Assign a Systems Champion</div>
      </div>
      <div class="syso-connector" id="sysoConn2"></div>

      <div class="syso-step" data-step="3" id="sysoStep3">
        <div class="syso-step-icon">3</div>
        <div class="syso-step-text">Document it (so it never happens again)</div>
      </div>
      <div class="syso-connector" id="sysoConn3"></div>

      <div class="syso-step final" data-step="4" id="sysoStep4">
        <div class="syso-step-text">System restored. Redirecting you now…</div>
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var steps = [
    document.getElementById('sysoStep1'),
    document.getElementById('sysoStep2'),
    document.getElementById('sysoStep3'),
    document.getElementById('sysoStep4')
  ];
  var connectors = [
    document.getElementById('sysoConn1'),
    document.getElementById('sysoConn2'),
    document.getElementById('sysoConn3')
  ];
  if (!steps[0]) return;

  var currentStep = 0;

  setTimeout(function() {
    steps[0].classList.add('visible');
    steps[0].classList.add('active');
  }, 800);

  steps.forEach(function(step, index) {
    step.addEventListener('click', function() {
      if (index !== currentStep) return;
      if (index === steps.length - 1) return;

      step.classList.remove('active');
      step.classList.add('completed');
      var icon = step.querySelector('.syso-step-icon');
      if (icon) icon.textContent = '\u2713';

      setTimeout(function() {
        if (connectors[index]) connectors[index].classList.add('visible');
      }, 200);

      currentStep = index + 1;
      setTimeout(function() {
        steps[currentStep].classList.add('visible');
        steps[currentStep].classList.add('active');
        if (currentStep === steps.length - 1) {
          setTimeout(function() {
            window.location.href = '/';
          }, 2200);
        }
      }, 500);
    });
  });
})();
</script>

